<?xml version="1.0" encoding="UTF-8"?>
<!--
  Smoke test suite: critical path regression runs before every deployment.

  Usage: mvn test -P smoke
-->
<suite name="Smoke Tests" verbose="3" parallel="classes" thread-count="2">
     <test name="Smoke - Critical Paths">
         <classes>
             <class name="com.qaframework.tests.LoginTest"/>
             <class name="com.qaframework.tests.ElementInteractionTest"/>
         </classes>
      </test>
</suite>
