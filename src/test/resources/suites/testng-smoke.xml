<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Suite" parallel="classes" thread-count="2">
  <listeners>
    <listener class-name="com.qaframework.listeners.AllureSeleniumListener"/>
    <listener class-name="com.qaframework.listeners.RetryAnalyzerListener"/>
  </listeners>
  <test name="Smoke Tests">
    <groups>
      <run>
        <include name="smoke"/>
      </run>
    </groups>
    <packages>
      <package name="com.qaframework.tests.smoke"/>
    </packages>
  </test>
</suite>
